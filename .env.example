PG_PASS=changeme
POSTGRES_PASSWORD=changeme
POSTGRES_USER=medicabinet
POSTGRES_DB=medicabinet_db
SECRET_KEY=change-me-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Registration control (default: true)
REGISTRATION_ENABLED=true

# Set to false only when running without HTTPS (local development)
COOKIE_SECURE=true

# OIDC / SSO login (optional — all three must be set to enable)
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=
OIDC_PROVIDER_NAME=SSO
OIDC_SCOPES=openid email profile

# Email notifications (optional — leave blank to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
